#include "esp_camera.h"
#include <WiFi.h>
#include <WebServer.h>

// ⚠️ご自身のWi-Fi情報に書き換えてください（GitHubに上げる時はこのままかダミーにしておくこと！）
const char* ssid = "Buffalo-G-F490";
const char* password = "YOUR_WIFI_PASSWORD"; 

WebServer server(80);

// WROVER_KIT用のカメラピン設定
#define PWDN_GPIO_NUM    -1
#define RESET_GPIO_NUM   -1
#define XCLK_GPIO_NUM    21
#define SIOD_GPIO_NUM    26
#define SIOC_GPIO_NUM    27
#define Y9_GPIO_NUM      35
#define Y8_GPIO_NUM      34
#define Y7_GPIO_NUM      39
#define Y6_GPIO_NUM      36
#define Y5_GPIO_NUM      19
#define Y4_GPIO_NUM      18
#define Y3_GPIO_NUM       5
#define Y2_GPIO_NUM       4
#define VSYNC_GPIO_NUM   25
#define HREF_GPIO_NUM    23
#define PCLK_GPIO_NUM    22

// --- ブラウザに表示する操作画面のHTML ---
// ※モーターの震えを防ぐため、oninput ではなく onchange（指を離した時だけ送信）に変更済み
const char* html_page = R"rawliteral(
<html><head><meta charset='utf-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>
<style>
  body { text-align:center; font-family:sans-serif; background:#f4f4f4;} 
  .slider { width:90%; max-width:400px; height:40px; margin-bottom:15px;} 
  img { width:100%; max-width:500px; border:2px solid #333; margin-bottom:20px;}
</style>
</head><body>
  <h2>Robot Arm Stream</h2>
  <img src="/stream" crossorigin="anonymous">
  
  <div><p>Motor 1: <span id='v0'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(0, this.value)'></div>
  <div><p>Motor 2: <span id='v1'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(1, this.value)'></div>
  <div><p>Motor 3: <span id='v2'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(2, this.value)'></div>
  <div><p>Motor 4: <span id='v3'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(3, this.value)'></div>
  <div><p>Motor 5: <span id='v4'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(4, this.value)'></div>
  <div><p>Motor 6: <span id='v5'>90</span>°</p><input type='range' min='0' max='180' value='90' class='slider' onchange='update(5, this.value)'></div>

  <script>
    function update(id, val){
      document.getElementById('v'+id).innerText = val;
      fetch('/set?id='+id+'&val='+val);
    }
  </script>
</body></html>
)rawliteral";

// トップページ（操作画面）へのアクセス処理
void handleRoot() {
  server.send(200, "text/html", html_page);
}

// スライダーからデータが送られてきた時の処理
void handleSet() {
  if (server.hasArg("id") && server.hasArg("val")) {
    String id = server.arg("id");
    String val = server.arg("val");
    
    // Arduino Unoへ「M0:120」のような形式でシリアル送信
    Serial1.print("M" + id + ":" + val + "\n");
    
    server.send(200, "text/plain", "OK");
  }
}

// カメラの映像（MJPEG）を配信し続ける処理
void handleStream() {
  WiFiClient client = server.client();
  String response = "HTTP/1.1 200 OK\r\n";
  response += "Content-Type: multipart/x-mixed-replace; boundary=frame\r\n\r\n";
  client.print(response);

  while (true) {
    camera_fb_t * fb = esp_camera_fb_get();
    if (!fb) { delay(50); continue; }

    client.printf("--frame\r\nContent-Type: image/jpeg\r\nContent-Length: %u\r\n\r\n", fb->len);
    client.write(fb->buf, fb->len);
    client.print("\r\n");

    esp_camera_fb_return(fb);
    if (!client.connected()) break; // ブラウザが閉じられたら停止
  }
}

void setup() {
  Serial.begin(115200);
  
  // Arduino Unoへデータを送るためのシリアル通信設定（TXピンとしてGPIO12を使用）
  Serial1.begin(9600, SERIAL_8N1, -1, 12); 

  // カメラの設定
  camera_config_t config;
  config.ledc_channel = LEDC_CHANNEL_0;
  config.ledc_timer = LEDC_TIMER_0;
  config.pin_d0 = Y2_GPIO_NUM; 
  config.pin_d1 = Y3_GPIO_NUM; 
  config.pin_d2 = Y4_GPIO_NUM; 
  config.pin_d3 = Y5_GPIO_NUM;
  config.pin_d4 = Y6_GPIO_NUM; 
  config.pin_d5 = Y7_GPIO_NUM; 
  config.pin_d6 = Y8_GPIO_NUM; 
  config.pin_d7 = Y9_GPIO_NUM;
  config.pin_xclk = XCLK_GPIO_NUM; 
  config.pin_pclk = PCLK_GPIO_NUM; 
  config.pin_vsync = VSYNC_GPIO_NUM; 
  config.pin_href = HREF_GPIO_NUM;
  config.pin_sscb_sda = SIOD_GPIO_NUM; 
  config.pin_sscb_scl = SIOC_GPIO_NUM;
  config.pin_pwdn = PWDN_GPIO_NUM; 
  config.pin_reset = RESET_GPIO_NUM;
  config.xclk_freq_hz = 20000000;
  config.pixel_format = PIXFORMAT_JPEG;
  config.frame_size = FRAMESIZE_VGA; // 解像度設定
  config.jpeg_quality = 12;
  config.fb_count = 2;

  // カメラの初期化
  if(esp_camera_init(&config) != ESP_OK) {
    Serial.println("Camera init failed!");
    return;
  }

  // Wi-Fi接続
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { 
    delay(500); 
    Serial.print("."); 
  }
  Serial.println("\nWiFi connected! Access the following IP:");
  Serial.println(WiFi.localIP());

  // サーバーのURLルーティング
  server.on("/", handleRoot);
  server.on("/set", handleSet);
  server.on("/stream", handleStream);
  
  server.begin();
}

void loop() {
  server.handleClient();
}
